# ---- eBird Gap Finder configuration ----
# Copy this file to ".env" and fill in your own values.

# Your personal, free eBird API key. Get one (requires an eBird account) at:
#   https://ebird.org/api/keygen
# This key is YOUR key. It stays server-side and is never shipped to the browser,
# committed, or sent anywhere but eBird. One key per self-hosted user — do not
# route many users through a single key.
EBIRD_API_TOKEN=

# Default "home" map location (editable in the UI). Defaults to Central Park, NYC —
# set these to wherever you bird.
DEFAULT_LAT=40.7829
DEFAULT_LNG=-73.9654

# Port the server listens on (also serves the built frontend in production).
PORT=3000

# Persistence for the parsed life list so you don't re-upload every run.
#   memory = in-memory only, lost on restart (default, zero-friction)
#   json   = local JSON file under ./data (survives restarts)
STORAGE_BACKEND=memory

# Where the on-disk taxonomy cache lives (large, rarely changes — fetched once).
CACHE_DIR=.cache

# TTL (seconds) for cached eBird observation responses. Keeps slider-dragging polite.
OBS_CACHE_TTL_SECONDS=300
